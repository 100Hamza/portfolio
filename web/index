<!DOCTYPE html>
<html lang="en">

<head>
    <base href="$FLUTTER_BASE_HREF">

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <meta name="description" content="Muhammad Hamza | Flutter Developer - Premium cross-platform apps">

    <title>Muhammad Hamza | Flutter Dev</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
        rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: #0a0c12;
            overflow: hidden;
            height: 100vh;
        }

        /* SPLASH SCREEN - FIXED OVERLAY */
        #splash {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 30%, #0f1222, #03050b);
            z-index: 9999;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.6s cubic-bezier(0.23, 1, 0.32, 1), visibility 0.6s;
            backdrop-filter: blur(2px);
        }

        /* Hidden state */
        #splash.hide-splash {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }

        /* Main content */
        .splash-content {
            text-align: center;
            max-width: 500px;
            padding: 2rem;
            animation: fadeInUp 0.8s ease-out;
        }

        /* Logo animation */
        .logo {
            font-size: 5rem;
            font-weight: 800;
            background: linear-gradient(135deg, #FFFFFF, #6ee7ff, #3b82f6);
            background-size: 200% auto;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: gradientShift 3s ease infinite, float 2.5s ease-in-out infinite;
            letter-spacing: 6px;
            margin-bottom: 0.5rem;
        }

        .tagline {
            color: #94a3b8;
            font-weight: 500;
            letter-spacing: 3px;
            font-size: 0.85rem;
            text-transform: uppercase;
            margin-bottom: 2rem;
            background: linear-gradient(120deg, #cbd5e1, #38bdf8);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        /* Loading bar container */
        .loader-container {
            background: rgba(30, 41, 59, 0.4);
            border-radius: 60px;
            padding: 0.3rem;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(56, 189, 248, 0.3);
            margin: 1.8rem 0;
        }

        .progress-bar {
            height: 6px;
            background: linear-gradient(90deg, #38bdf8, #818cf8, #c084fc);
            border-radius: 60px;
            width: 0%;
            transition: width 0.15s linear;
            box-shadow: 0 0 8px #38bdf8;
        }

        .status {
            display: flex;
            justify-content: space-between;
            font-size: 0.75rem;
            font-weight: 500;
            font-family: monospace;
            margin-top: 0.6rem;
            color: #7e8ba3;
        }

        .status-message {
            color: #38bdf8;
            text-transform: uppercase;
        }

        .status-percent {
            color: #a5f3fc;
        }

        /* Tech badges */
        .badges {
            display: flex;
            gap: 16px;
            justify-content: center;
            margin-top: 2rem;
        }

        .badge {
            background: rgba(56, 189, 248, 0.1);
            backdrop-filter: blur(4px);
            padding: 0.3rem 1rem;
            border-radius: 30px;
            font-size: 0.7rem;
            font-weight: 500;
            color: #b9d0f0;
            border: 0.5px solid rgba(56, 189, 248, 0.3);
            letter-spacing: 0.5px;
        }

        /* Decorative rings */
        .rings {
            position: absolute;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }

        .ring {
            position: absolute;
            top: 50%;
            left: 50%;
            border-radius: 50%;
            border: 1px solid rgba(56, 189, 248, 0.2);
            transform: translate(-50%, -50%);
        }

        .ring1 {
            width: 300px;
            height: 300px;
            animation: spin 20s linear infinite;
        }

        .ring2 {
            width: 450px;
            height: 450px;
            border-width: 1.5px;
            border-color: rgba(56, 189, 248, 0.15);
            border-top-color: #38bdf8;
            animation: spin 25s reverse linear infinite;
        }

        .ring3 {
            width: 600px;
            height: 600px;
            border-style: dashed;
            animation: spin 35s linear infinite;
        }

        /* Animations */
        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        @keyframes float {
            0% {
                transform: translateY(0px);
            }

            50% {
                transform: translateY(-6px);
            }

            100% {
                transform: translateY(0px);
            }
        }

        @keyframes spin {
            from {
                transform: translate(-50%, -50%) rotate(0deg);
            }

            to {
                transform: translate(-50%, -50%) rotate(360deg);
            }
        }

        /* Responsive */
        @media (max-width: 550px) {
            .logo {
                font-size: 3rem;
                letter-spacing: 3px;
            }

            .tagline {
                font-size: 0.7rem;
                letter-spacing: 2px;
            }

            .badge {
                font-size: 0.6rem;
                padding: 0.2rem 0.8rem;
            }
        }
    </style>
</head>

<body>

    <!-- SPLASH SCREEN -->
    <div id="splash">
        <div class="rings">
            <div class="ring ring1"></div>
            <div class="ring ring2"></div>
            <div class="ring ring3"></div>
        </div>
        <div class="splash-content">
            <div class="logo">HAMZA</div>
            <div class="tagline">FLUTTER ARTISAN</div>

            <div class="loader-container">
                <div class="progress-bar" id="progressBar"></div>
            </div>
            <div class="status">
                <span class="status-message" id="statusMsg">✦ INITIALIZING</span>
                <span class="status-percent" id="percentVal">0%</span>
            </div>

            <div class="badges">
                <span class="badge">DART 3.6</span>
                <span class="badge">FLUTTER 3.29</span>
                <span class="badge">WEB READY</span>
            </div>
        </div>
    </div>

    <!-- FLUTTER BOOTSTRAP (your existing file) -->
    <script src="flutter_bootstrap.js" async></script>

    <script>
        (function () {
            // --------------------------------------------------------------
            // 1. SIMULATE LOADING PROGRESS (just for visual flair)
            // --------------------------------------------------------------
            let progress = 0;
            const progressBar = document.getElementById('progressBar');
            const percentSpan = document.getElementById('percentVal');
            const msgSpan = document.getElementById('statusMsg');

            const stages = [
                { text: "⚡ SPINNING UP DART VM", cap: 15 },
                { text: "🌀 LOADING WIDGETS", cap: 32 },
                { text: "🎨 RENDERING FRAMEWORK", cap: 51 },
                { text: "🔗 CONNECTING STATE", cap: 68 },
                { text: "✨ OPTIMIZING UI", cap: 85 },
                { text: "🚀 ALMOST THERE", cap: 97 },
                { text: "✅ READY", cap: 100 }
            ];

            let progressInterval = setInterval(() => {
                if (progress < 100) {
                    let inc = 0;
                    if (progress < 40) inc = Math.random() * 1.5 + 0.7;
                    else if (progress < 75) inc = Math.random() * 1.2 + 0.5;
                    else inc = Math.random() * 0.6 + 0.3;
                    progress = Math.min(progress + inc, 100);

                    progressBar.style.width = progress + '%';
                    percentSpan.innerText = Math.floor(progress) + '%';

                    // update status message based on progress
                    for (let i = stages.length - 1; i >= 0; i--) {
                        if (progress >= stages[i].cap) {
                            if (msgSpan.innerText !== stages[i].text) {
                                msgSpan.innerText = stages[i].text;
                            }
                            break;
                        }
                    }
                } else {
                    clearInterval(progressInterval);
                }
            }, 40);

            // --------------------------------------------------------------
            // 2. RELIABLE SPLASH REMOVAL WHEN FLUTTER LOADS
            // --------------------------------------------------------------
            let splashRemoved = false;
            const splashElement = document.getElementById('splash');

            function removeSplashScreen() {
                if (splashRemoved) return;
                splashRemoved = true;

                if (splashElement) {
                    splashElement.classList.add('hide-splash');
                    // remove from DOM after transition
                    setTimeout(() => {
                        if (splashElement && splashElement.parentNode) {
                            splashElement.parentNode.removeChild(splashElement);
                        }
                    }, 700);
                }
                // stop progress animation to save resources
                if (progressInterval) clearInterval(progressInterval);
            }

            // --- METHOD 1: Listen for Flutter's first frame event (BEST) ---
            window.addEventListener('flutter-first-frame', function () {
                console.log('Flutter first frame detected');
                removeSplashScreen();
            });

            // --- METHOD 2: MutationObserver to detect Flutter's canvas ---
            const observer = new MutationObserver(() => {
                // Look for a canvas that is NOT the splash background (but we don't have one now)
                // Just detect any canvas that appears inside body (Flutter renders a canvas)
                const canvases = document.querySelectorAll('canvas');
                for (let canvas of canvases) {
                    // If canvas has size and is not part of splash (splash has no canvas)
                    if (canvas.width > 100 && canvas.height > 100) {
                        observer.disconnect();
                        removeSplashScreen();
                        return;
                    }
                }
                // Also detect if any element with class 'flutter-view' or similar appears
                const flutterRoot = document.querySelector('[data-flutter], .flutter-view, #flutter-view');
                if (flutterRoot) {
                    observer.disconnect();
                    removeSplashScreen();
                }
            });

            observer.observe(document.body, { childList: true, subtree: true });

            // --- METHOD 3: Fallback timeout (max 8 seconds) ---
            setTimeout(() => {
                if (!splashRemoved) {
                    console.log('Fallback timeout: removing splash');
                    removeSplashScreen();
                }
            }, 8000);

            // --- METHOD 4: Early check after 1 second (in case Flutter loaded super fast) ---
            setTimeout(() => {
                const existingCanvas = document.querySelector('canvas');
                if (existingCanvas && existingCanvas.width > 100) {
                    removeSplashScreen();
                }
            }, 1000);

            // --- METHOD 5: Watch for load event (if Flutter bootstrap triggers it) ---
            window.addEventListener('load', function () {
                // small delay to allow Flutter to paint
                setTimeout(() => {
                    if (!splashRemoved) {
                        // check again
                        const flutterCanvas = document.querySelector('canvas');
                        if (flutterCanvas && flutterCanvas.width > 100) {
                            removeSplashScreen();
                        }
                    }
                }, 300);
            });

        })();
    </script>
</body>

</html>